# ============================================================
# Plantilla del .env LOCAL — copiar a .env en la raíz:
#   copy .env.example .env
# Un solo archivo para el backend y la base de datos de desarrollo.
#
# Los .env del front NO van acá: viven en apps/web/.env.development (local)
# y apps/web/.env.production (prod) — Next.js elige solo. Ver ENV.md.
# ============================================================

# --- API (NestJS) ---
NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/comercia?schema=public"
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
SWAGGER_ENABLED=true
COOKIE_SECRET="change-this-secret-before-production-please-use-64-random-chars"

# --- Postgres de desarrollo (lo usa docker compose para crear el contenedor) ---
# ⚠️ Si tenés un PostgreSQL nativo de Windows ocupando el puerto 5432, poné 5433
# acá Y en el puerto de DATABASE_URL (ver "Problemas comunes" en SETUP.md).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=comercia
POSTGRES_PORT=5432
