// Esquema de datos de Comercia.
// Cambios de estructura: editar acá y correr `npm run prisma:migrate` (con la
// DATABASE_URL LOCAL activa); la migración llega a producción sola con el push.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // El build de Nest (tsc) compila a CommonJS; sin esto el generador emite
  // código ESM (import.meta) que rompe node dist/src/main.js en producción.
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Empresa {
  id               Int               @id @default(autoincrement())
  nombre           String            @unique
  dbName           String?           @map("db_name")
  // Una empresa puede pertenecer a otra (casa matriz → sucursales)
  empresaId        Int?              @map("empresas_id")
  padre            Empresa?          @relation("EmpresaJerarquia", fields: [empresaId], references: [id])
  hijas            Empresa[]         @relation("EmpresaJerarquia")
  usuarios         Usuario[]
  modulos          EmpresaModulo[]
  paginas          EmpresaPagina[]
  clientes         Cliente[]         @relation("EmpresaClientes")
  tareasGlobales   TareaGlobal[]     @relation("EmpresaTareasGlobales")
  locales          Local[]           @relation("EmpresaLocales")
  territorios      Territorio[]      @relation("EmpresaTerritorios")
  zonas            Zona[]            @relation("EmpresaZonas")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")

  @@map("empresas")
}

model Conexion {
  id           Int          @id @default(autoincrement())
  nombre       String       @unique
  servernode   String?
  userDb       String?      @map("user_db")
  passwordDb   String?      @map("password_db")
  serviceLayer String?      @map("service_layer")
  versionTls   String?      @map("version_tls")
  ejecutables  Ejecutable[]
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at")

  @@map("conexiones")
}

// ============================================================
// Plataforma modular: una empresa habilita módulos; cada módulo tiene páginas;
// cada página tiene ejecutables (proc/función/vista/query contra el motor que
// sea). Todo se configura por tabla desde el ABM del superadmin.
// ============================================================

// Qué tipo de objeto de base de datos ejecuta la página
enum TipoEjecutable {
  PROCEDURE
  FUNCTION
  VIEW
  QUERY
}

// Motor donde vive el ejecutable. Hoy se ejecuta de verdad POSTGRESQL; el resto
// queda declarado para configurarse y activarse cuando exista su driver+servidor.
enum MotorBd {
  POSTGRESQL
  SAP_HANA
  ORACLE
  MYSQL
  SQLSERVER
}

model Modulo {
  id        Int             @id @default(autoincrement())
  nombre    String
  // Segmento de ruta del módulo (ej. "ventas"). Único entre módulos.
  ruta      String          @unique
  icono     String?
  orden     Int             @default(0)
  activo    Boolean         @default(true)
  paginas   Pagina[]
  empresas  EmpresaModulo[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @default(now()) @updatedAt @map("updated_at")

  @@map("modulos")
}

model Pagina {
  id          Int             @id @default(autoincrement())
  moduloId    Int             @map("modulo_id")
  modulo      Modulo          @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  nombre      String
  // Segmento de ruta dentro del módulo (ej. "listado"). Único por módulo.
  ruta        String
  icono       String?
  orden       Int             @default(0)
  activo      Boolean         @default(true)
  ejecutables Ejecutable[]
  empresas    EmpresaPagina[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")

  @@unique([moduloId, ruta])
  @@map("paginas")
}

model Ejecutable {
  id         Int            @id @default(autoincrement())
  paginaId   Int            @map("pagina_id")
  pagina     Pagina         @relation(fields: [paginaId], references: [id], onDelete: Cascade)
  nombre     String
  tipo       TipoEjecutable
  motor      MotorBd        @default(POSTGRESQL)
  // Conexión externa (SAP HANA, Oracle, ...). null = base propia de comercIA.
  conexionId Int?           @map("conexion_id")
  conexion   Conexion?      @relation(fields: [conexionId], references: [id])
  // Nombre del proc/función/vista o la sentencia SQL a ejecutar
  sentencia  String
  orden      Int            @default(0)
  activo     Boolean        @default(true)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @default(now()) @updatedAt @map("updated_at")

  @@map("ejecutables")
}

// Una empresa habilita un módulo. `todasLasPaginas` = ve todas las páginas del
// módulo; si es false, solo las listadas en EmpresaPagina.
// `rolIds` = roles que ven el módulo dentro de la empresa; vacío = todos los roles.
model EmpresaModulo {
  id              Int      @id @default(autoincrement())
  empresaId       Int      @map("empresa_id")
  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  moduloId        Int      @map("modulo_id")
  modulo          Modulo   @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  todasLasPaginas Boolean  @default(true) @map("todas_las_paginas")
  rolIds          Int[]    @default([]) @map("rol_ids")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([empresaId, moduloId])
  @@map("empresa_modulos")
}

// Páginas específicas que ve una empresa (cuando su módulo no es todasLasPaginas).
// `rolIds` = roles que ven ESTA página; vacío = todos los roles del módulo.
model EmpresaPagina {
  id        Int      @id @default(autoincrement())
  empresaId Int      @map("empresa_id")
  empresa   Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  paginaId  Int      @map("pagina_id")
  pagina    Pagina   @relation(fields: [paginaId], references: [id], onDelete: Cascade)
  rolIds    Int[]    @default([]) @map("rol_ids")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([empresaId, paginaId])
  @@map("empresa_paginas")
}

// ============================================================
// Operaciones de campo: jerarquía geográfica (territorio > zona > local),
// checklist por local y visitas con verificación de ubicación.
// ============================================================

// Territorio geográfico de una empresa (nivel superior de la jerarquía).
// El polígono se dibuja en el mapa y se guarda como [[lat, lng], ...].
model Territorio {
  id            Int      @id @default(autoincrement())
  empresaId     Int      @map("empresa_id")
  empresa       Empresa  @relation("EmpresaTerritorios", fields: [empresaId], references: [id], onDelete: Cascade)
  nombre        String
  // Color de relleno en el mapa (hex #rrggbb)
  color         String   @default("#047857")
  // Vértices del área [[lat, lng], ...]; null = sin delimitar todavía
  poligono      Json?
  activo        Boolean  @default(true)
  zonas         Zona[]
  responsableId Int?     @map("responsable_id")
  responsable   Usuario? @relation("TerritoriosResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  creadoPorId   Int      @map("creado_por_id")
  creadoPor     Usuario  @relation("TerritoriosCreados", fields: [creadoPorId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("territorios")
}

// Zona dentro de un territorio; agrupa locales.
model Zona {
  id           Int           @id @default(autoincrement())
  empresaId    Int           @map("empresa_id")
  empresa      Empresa       @relation("EmpresaZonas", fields: [empresaId], references: [id], onDelete: Cascade)
  territorioId Int           @map("territorio_id")
  // Borrar un territorio borra sus zonas (los locales quedan sin zona)
  territorio   Territorio    @relation(fields: [territorioId], references: [id], onDelete: Cascade)
  nombre       String
  color        String        @default("#0284c7")
  poligono     Json?
  activo       Boolean       @default(true)
  locales      Local[]
  repositores  ZonaUsuario[]
  creadoPorId  Int           @map("creado_por_id")
  creadoPor    Usuario       @relation("ZonasCreadas", fields: [creadoPorId], references: [id])
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at")

  @@map("zonas")
}

// Repositores habilitados para trabajar dentro de una zona.
model ZonaUsuario {
  id            Int      @id @default(autoincrement())
  zonaId        Int      @map("zona_id")
  zona          Zona     @relation(fields: [zonaId], references: [id], onDelete: Cascade)
  usuarioId     Int      @map("usuario_id")
  usuario       Usuario  @relation("ZonasAsignadas", fields: [usuarioId], references: [id], onDelete: Cascade)
  asignadoPorId Int      @map("asignado_por_id")
  asignadoPor   Usuario  @relation("ZonasAsignadasPor", fields: [asignadoPorId], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([zonaId, usuarioId])
  @@map("zona_usuarios")
}

// Cliente comercial: puede tener varios locales y un checklist global.
model Cliente {
  id                Int            @id @default(autoincrement())
  empresaId         Int            @map("empresa_id")
  empresa           Empresa        @relation("EmpresaClientes", fields: [empresaId], references: [id], onDelete: Cascade)
  nombre            String
  descripcionTareas String         @default("") @map("descripcion_tareas")
  imagenReferencia  String?        @map("imagen_referencia")
  activo            Boolean        @default(true)
  locales           Local[]
  tareas            TareaCliente[]
  creadoPorId       Int            @map("creado_por_id")
  creadoPor         Usuario        @relation("ClientesCreados", fields: [creadoPorId], references: [id])
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at")

  @@unique([empresaId, nombre])
  @@map("clientes")
}

// Definición maestra del checklist de una empresa. Cada cambio se replica en
// TareaCliente para conservar IDs estables y el historial de cada visita.
model TareaGlobal {
  id           Int            @id @default(autoincrement())
  empresaId    Int            @map("empresa_id")
  empresa      Empresa        @relation("EmpresaTareasGlobales", fields: [empresaId], references: [id], onDelete: Cascade)
  titulo       String
  descripcion  String
  requiereFoto Boolean        @default(false) @map("requiere_foto")
  orden        Int            @default(0)
  activo       Boolean        @default(true)
  tareas       TareaCliente[]
  creadoPorId  Int            @map("creado_por_id")
  creadoPor    Usuario        @relation("TareasGlobalesCreadas", fields: [creadoPorId], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")

  @@unique([empresaId, titulo])
  @@map("tareas_globales")
}

// Locales geolocalizados. Los carga un Team Leader y puede asignarlos a un
// Repositor de su misma empresa.
model Local {
  id                    Int       @id @default(autoincrement())
  empresaId             Int       @map("empresa_id")
  empresa               Empresa   @relation("EmpresaLocales", fields: [empresaId], references: [id], onDelete: Cascade)
  nombre                String
  clienteId             Int       @map("cliente_id")
  cliente               Cliente   @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  latitud               Float
  longitud              Float
  // Zona a la que pertenece (opcional hasta que el gestor la asigne)
  zonaId                Int?      @map("zona_id")
  zona                  Zona?     @relation(fields: [zonaId], references: [id], onDelete: SetNull)
  // Radio en metros para verificar presencia; null = usa 200 metros
  radioMetros           Int?      @map("radio_metros")
  // Próxima visita programada por el gestor
  fechaVisita           DateTime? @map("fecha_visita")
  // El gestor exige una foto de presencia al finalizar la visita
  requiereFotoPresencia Boolean   @default(false) @map("requiere_foto_presencia")
  // Repositor al que se le asigna el local (opcional)
  usuarioId             Int?      @map("usuario_id")
  usuario               Usuario?  @relation("LocalesAsignados", fields: [usuarioId], references: [id], onDelete: SetNull)
  // Quién lo cargó (rol gestor)
  creadoPorId           Int       @map("creado_por_id")
  creadoPor             Usuario   @relation("LocalesCreados", fields: [creadoPorId], references: [id])
  activo                Boolean   @default(true)
  visitas               Visita[]
  programacionVisita    ProgramacionVisita?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("locales")
}

enum FrecuenciaVisita {
  UNICA
  SEMANAL
  MENSUAL
}

// Agenda editable del local. Una programación admite varias ocurrencias el
// mismo día mediante `horarios` y recurrencias cada N semanas o meses.
model ProgramacionVisita {
  id           Int              @id @default(autoincrement())
  localId      Int              @unique @map("local_id")
  local        Local            @relation(fields: [localId], references: [id], onDelete: Cascade)
  frecuencia   FrecuenciaVisita
  fechaInicio  DateTime         @db.Date @map("fecha_inicio")
  fechaFin     DateTime?        @db.Date @map("fecha_fin")
  intervalo    Int              @default(1)
  // ISO-8601: lunes = 1, domingo = 7.
  diasSemana   Int[]            @default([]) @map("dias_semana")
  diasMes      Int[]            @default([]) @map("dias_mes")
  // Horas locales HH:mm, ordenadas y sin duplicados.
  horarios     String[]
  zonaHoraria  String           @default("America/Asuncion") @map("zona_horaria")
  activo       Boolean          @default(true)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at")

  @@map("programaciones_visita")
}

// Ítem del checklist de un local. `requiereFoto` habilita la cámara para
// esa tarea durante la visita.
model TareaCliente {
  id            Int           @id @default(autoincrement())
  clienteId     Int           @map("cliente_id")
  cliente       Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tareaGlobalId Int?          @map("tarea_global_id")
  tareaGlobal   TareaGlobal?  @relation(fields: [tareaGlobalId], references: [id], onDelete: SetNull)
  titulo        String
  descripcion   String
  requiereFoto  Boolean       @default(false) @map("requiere_foto")
  orden         Int           @default(0)
  activo        Boolean       @default(true)
  respuestas    VisitaTarea[]
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at")

  @@unique([clienteId, tareaGlobalId])
  @@map("tareas_cliente")
}

// Visita de un usuario a un local. La ubicación reportada se verifica contra
// el radio del local y queda registrada con fecha y hora.
model Visita {
  id                 Int           @id @default(autoincrement())
  localId            Int           @map("local_id")
  local              Local         @relation(fields: [localId], references: [id], onDelete: Cascade)
  usuarioId          Int           @map("usuario_id")
  usuario            Usuario       @relation("VisitasRealizadas", fields: [usuarioId], references: [id], onDelete: Cascade)
  iniciadaEn         DateTime      @default(now()) @map("iniciada_en")
  completadaEn       DateTime?     @map("completada_en")
  // Ubicación reportada al iniciar y su distancia al local
  latitud            Float
  longitud           Float
  distanciaMetros    Float         @map("distancia_metros")
  // Ubicación reportada al finalizar (botón "Registrar visita")
  latitudFin         Float?        @map("latitud_fin")
  longitudFin        Float?        @map("longitud_fin")
  distanciaFinMetros Float?        @map("distancia_fin_metros")
  // Nombre de archivo de la foto de presencia (en UPLOADS_DIR del servidor)
  fotoPresencia      String?       @map("foto_presencia")
  tareas             VisitaTarea[]
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @default(now()) @updatedAt @map("updated_at")

  @@index([localId, usuarioId])
  @@index([iniciadaEn])
  @@index([completadaEn])
  @@map("visitas")
}

// Estado de cada tarea del checklist dentro de una visita.
model VisitaTarea {
  id           Int          @id @default(autoincrement())
  visitaId     Int          @map("visita_id")
  visita       Visita       @relation(fields: [visitaId], references: [id], onDelete: Cascade)
  tareaId      Int          @map("tarea_id")
  tarea        TareaCliente @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  completada   Boolean      @default(false)
  comentario   String?
  // Nombre de archivo de la foto tomada para esta tarea
  foto         String?
  completadaEn DateTime?    @map("completada_en")

  @@unique([visitaId, tareaId])
  @@map("visita_tareas")
}

model Rol {
  id          Int       @id @default(autoincrement())
  descripcion String    @unique
  // Jerarquía de roles: un rol puede depender de otro (se auto-apunta)
  rolId       Int?      @map("roles_id")
  padre       Rol?      @relation("RolJerarquia", fields: [rolId], references: [id])
  hijos       Rol[]     @relation("RolJerarquia")
  usuarios    Usuario[]

  @@map("roles")
}

model Usuario {
  id                     Int           @id @default(autoincrement())
  empresaId              Int           @map("empresa_id")
  empresa                Empresa       @relation(fields: [empresaId], references: [id])
  nombre                 String
  apellido               String
  // Identificadores de login: cualquiera de los dos + contraseña
  correo                 String        @unique
  nombreLogin            String        @unique @map("nombre_login")
  passwordHash           String        @map("password_hash")
  ruc                    String        @unique
  celular                String
  // Sin rol al registrarse: un superior se lo asigna después
  rolId                  Int?          @map("rol_id")
  rol                    Rol?          @relation(fields: [rolId], references: [id])
  // Jerarquía: el superior es otro usuario (ej. el jefe)
  superiorId             Int?          @map("superior_id")
  superior               Usuario?      @relation("UsuarioJerarquia", fields: [superiorId], references: [id])
  subordinados           Usuario[]     @relation("UsuarioJerarquia")
  // Permiso de administración del sistema (configura el ABM de la plataforma).
  // Independiente del rol de negocio. Se activa a mano en la BD.
  esSuperadmin           Boolean       @default(false) @map("es_superadmin")
  localesAsignados       Local[]       @relation("LocalesAsignados")
  localesCreados         Local[]       @relation("LocalesCreados")
  clientesCreados        Cliente[]     @relation("ClientesCreados")
  tareasGlobalesCreadas  TareaGlobal[] @relation("TareasGlobalesCreadas")
  territoriosCreados     Territorio[]  @relation("TerritoriosCreados")
  territoriosResponsable Territorio[]  @relation("TerritoriosResponsable")
  zonasCreadas           Zona[]        @relation("ZonasCreadas")
  zonasAsignadas         ZonaUsuario[] @relation("ZonasAsignadas")
  zonasAsignadasPor      ZonaUsuario[] @relation("ZonasAsignadasPor")
  visitas                Visita[]      @relation("VisitasRealizadas")
  isActive               Boolean       @default(true) @map("is_active")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @default(now()) @updatedAt @map("updated_at")

  @@map("usuarios")
}
